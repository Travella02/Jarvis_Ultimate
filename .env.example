# Copy this to .env later if needed.
# Jarvis reads this file automatically. Real OS environment variables still win.

JARVIS_ENV=development

# Local LLM provider through LM Studio.
JARVIS_LLM_PROVIDER=lm_studio
JARVIS_LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# Use auto for LM Studio's fast path, or put the exact id shown in LM Studio.
# Example: JARVIS_LLM_MODEL=google/gemma-4-12b-qat
JARVIS_LLM_MODEL=auto

JARVIS_LLM_TIMEOUT_SECONDS=90
JARVIS_LLM_TEMPERATURE=0.7
JARVIS_LLM_MAX_TOKENS=512
JARVIS_LLM_STREAMING=true
JARVIS_LLM_RESOLVE_AUTO_MODEL=false

# 0.0.5c LM Studio API mode diagnostics.
# openai = /v1/chat/completions. native = /api/v1/chat.
# Try native + reasoning off if LM Studio's direct chat UI is faster with Thinking off.
JARVIS_LLM_API_MODE=openai
# Keep 127.0.0.1 on Windows to avoid localhost loopback delays.
JARVIS_LM_STUDIO_NATIVE_BASE_URL=http://127.0.0.1:1234
JARVIS_LLM_REASONING=auto
# Optional. Leave blank/default unless you are testing LM Studio context-length behavior.
JARVIS_LLM_CONTEXT_LENGTH=
JARVIS_LLM_STORE_NATIVE_CHATS=false

# 0.0.5a also accepts these shorter aliases if you already used them:
# JARVIS_LM_PROVIDER=lm_studio
# JARVIS_LM_MODEL=auto
# JARVIS_LM_TIMEOUT_SECONDS=90
# JARVIS_LM_TEMPERATURE=0.7
# JARVIS_LM_MAX_TOKENS=512
# JARVIS_LM_STREAMING=true
# JARVIS_LM_RESOLVE_AUTO_MODEL=false
# JARVIS_LM_API_MODE=openai
# JARVIS_LM_STUDIO_NATIVE_BASE_URL=http://127.0.0.1:1234
# JARVIS_LM_NATIVE_BASE_URL=http://127.0.0.1:1234
# JARVIS_LM_REASONING=auto
# JARVIS_LM_THINKING=off
# JARVIS_LM_CONTEXT_LENGTH=

# 0.0.5b LLM structure/speed diagnostics.
# normal = full Jarvis system prompt, minimal/fast = shorter prompt, off = no system prompt.
JARVIS_CONVERSATION_PROMPT_MODE=normal
# Used by the CLI command: benchmark llm
JARVIS_LLM_BENCHMARK_MAX_TOKENS=64
JARVIS_LLM_BENCHMARK_PROMPT="Reply with exactly one short sentence saying you are ready."

# 0.0.6 short-term conversation memory.
# This is a bounded rolling session window for follow-up questions.
# It is not permanent long-term memory. Keep limits bounded because Jarvis is
# intended to eventually run for long periods.
JARVIS_MEMORY_SHORT_TERM_ENABLED=true
JARVIS_MEMORY_SHORT_TERM_MAX_TURNS=20
JARVIS_MEMORY_SHORT_TERM_MAX_CHARS=12000
JARVIS_MEMORY_SHORT_TERM_INJECT_LAST_TURNS=8
# false = memory is in-process only. true = restore the recent session from data/conversations/short_term_session.json.
JARVIS_MEMORY_SHORT_TERM_AUTOSAVE=false

# 0.2.9 always-on temporary memory facts.
# These are useful facts Jarvis can keep for a few days without making them permanent.
JARVIS_MEMORY_SHORT_TERM_FACT_ENABLED=true
JARVIS_MEMORY_SHORT_TERM_FACT_MAX_RECORDS=300
JARVIS_MEMORY_SHORT_TERM_FACT_DEFAULT_DAYS=3
JARVIS_MEMORY_SHORT_TERM_FACT_INJECT_LIMIT=3
JARVIS_MEMORY_SHORT_TERM_FACT_PATH=data/memory/short_term_memory.json

# 0.2.8 permanent long-term memory.
JARVIS_MEMORY_LONG_TERM_ENABLED=true
JARVIS_MEMORY_LONG_TERM_MAX_RECORDS=0
JARVIS_MEMORY_LONG_TERM_INJECT_LIMIT=5
JARVIS_MEMORY_LONG_TERM_PATH=data/memory/long_term_memory.json

# 0.2.9 chat archive memory.
# Jarvis writes chat turns incrementally to daily JSONL files so long uptime does not depend on restarts.
JARVIS_MEMORY_CHAT_ARCHIVE_ENABLED=true
JARVIS_MEMORY_CHAT_ARCHIVE_DIR=data/memory/chat_archive
JARVIS_MEMORY_CHAT_ARCHIVE_MAX_SEARCH_DAYS=30
JARVIS_MEMORY_CHAT_ARCHIVE_RETENTION_DAYS=90
JARVIS_MEMORY_MAINTENANCE_INTERVAL_SECONDS=300


# 0.0.7c TTS voice output foundation.
# Kokoro is now the default local TTS provider because it is much easier to
# install/run than XTTS and is the cleaner path for a future SaaS-ready Jarvis.
# Install on another machine with:
#   python -m pip install -r requirements-tts.txt
JARVIS_TTS_ENABLED=true
JARVIS_TTS_PROVIDER=kokoro
JARVIS_TTS_FALLBACK_PROVIDERS=mock
JARVIS_TTS_OUTPUT_DIR=data/tts
# Jarvis assistant identity. Kokoro's actual voice id is below.
JARVIS_TTS_VOICE_NAME=jarvis
JARVIS_TTS_VOICE_PROFILES_DIR=data/tts/voices
JARVIS_TTS_LANGUAGE=en
JARVIS_TTS_DEVICE=auto
JARVIS_TTS_USE_GPU=false
# false = generate files only. true = try to play WAV files after generation.
JARVIS_TTS_PLAYBACK=false
# false by default so CLI chat does not speak every reply until you run voice on.
JARVIS_TTS_AUTO_SPEAK=false
# Common Kokoro voice IDs include af_heart, af_bella, af_sarah, am_adam, am_liam,
# bf_emma, bm_george, and more. Run: tts voice list
JARVIS_TTS_KOKORO_VOICE=af_heart
JARVIS_TTS_KOKORO_LANG_CODE=a
# 0.1.2 retention cleanup for always-running Jarvis.
JARVIS_TTS_MAX_OUTPUT_FILES=30
JARVIS_TTS_DELETE_AFTER_PLAYBACK=false

# XTTS experimental/personal-only notes.
# XTTS v2 caused dependency friction on the laptop and is not the default path.
# Its public model license is non-commercial, so do not use XTTS outputs for
# SaaS/commercial Jarvis unless a separate commercial license is obtained.
# Keep these only if manually testing XTTS later:
JARVIS_TTS_XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
JARVIS_TTS_XTTS_SPEAKER_WAV=assets/voices/jarvis_reference.wav
# Optional experimental install file for later, not needed for Kokoro:
#   python -m pip install -r requirements-tts-xtts-experimental.txt


# 0.0.9 STT / microphone input foundation.
# Install on another machine with:
#   python -m pip install -r requirements-stt.txt
# Default is faster-whisper for local/offline transcription, with mock fallback
# so Jarvis can still boot and tests can run without a microphone/model.
JARVIS_STT_ENABLED=true
JARVIS_STT_PROVIDER=faster_whisper
JARVIS_STT_FALLBACK_PROVIDERS=mock
JARVIS_STT_MODEL=base.en
# 0.0.9c default: keep STT on CPU/int8 for a stable, dependency-light path.
# Set JARVIS_STT_DEVICE=auto or cuda later after CUDA/cuBLAS/cuDNN DLLs are configured.
JARVIS_STT_DEVICE=cpu
JARVIS_STT_COMPUTE_TYPE=int8
JARVIS_STT_GPU_FALLBACK_TO_CPU=true
JARVIS_STT_DEVICE_INDEX=0
# For an always-running Jarvis, you can set this true after GPU STT is stable so
# the model loads during boot instead of on the first spoken request.
JARVIS_STT_WARMUP_ON_BOOT=false
JARVIS_STT_LANGUAGE=en
JARVIS_STT_OUTPUT_DIR=data/stt
# 0.0.9c low-latency listen mode. smart stops after you finish speaking.
# Use fixed only when you want a strict timer.
JARVIS_STT_LISTEN_MODE=smart
# Fixed timer fallback / command: listen fixed 2
JARVIS_STT_RECORD_SECONDS=2.0
# Smart endpointing command: listen once
JARVIS_STT_MAX_LISTEN_SECONDS=6.0
JARVIS_STT_SILENCE_SECONDS=0.65
JARVIS_STT_MIN_RECORD_SECONDS=0.20
JARVIS_STT_START_TIMEOUT_SECONDS=3.0
JARVIS_STT_ENERGY_THRESHOLD=0.018
JARVIS_STT_ADAPTIVE_ENERGY=true
JARVIS_STT_AMBIENT_CALIBRATION_SECONDS=0.35
JARVIS_STT_ENERGY_MULTIPLIER=3.0
JARVIS_STT_PRE_ROLL_SECONDS=0.25
JARVIS_STT_FRAME_MS=30
JARVIS_STT_SAMPLE_RATE=16000
JARVIS_STT_CHANNELS=1
# Leave blank for Windows default microphone, or set a sounddevice device id/name later.
JARVIS_STT_MICROPHONE_DEVICE=
JARVIS_STT_VAD_FILTER=true
JARVIS_STT_MOCK_TEXT="Hello sir, this is a mock transcription."
JARVIS_STT_MAX_AUDIO_FILES=30

# Useful CLI STT commands:
#   stt status
#   stt gpu status
#   stt warmup
#   stt providers
#   stt listen settings
#   stt record
#   listen once
#   listen smart max 8 silence 0.8
#   listen fixed 2
#   stt transcribe C:\path\to\audio.wav
#   stt debug last

# 0.1.1 wake-word foundation.
# This is phrase detection over the STT transcript, not continuous background
# wake-word listening yet. It lets you test commands like:
#   wake test Hey Jarvis, give me one sentence
#   wake listen once
#   wake voice once
JARVIS_WAKE_WORD_ENABLED=true
JARVIS_WAKE_WORD_PROVIDER=phrase
JARVIS_WAKE_WORDS="hey jarvis,jarvis,yo jarvis,okay jarvis,ok jarvis"
JARVIS_WAKE_REQUIRE_WAKE_WORD=true
JARVIS_WAKE_STRIP_WAKE_WORD=true
JARVIS_WAKE_EMPTY_RESPONSE="Yes, sir?"

# 0.1.5 always-ready startup. Jarvis can warm voice systems automatically,
# then enter sleep mode and wait for a wake phrase as his normal running state.
JARVIS_VOICE_WARMUP_ON_BOOT=true
JARVIS_VOICE_WARMUP_STT=true
JARVIS_VOICE_WARMUP_TTS=true
# Keep LLM warmup off unless LM Studio is running and you specifically want boot to test it.
JARVIS_VOICE_WARMUP_LLM=false
JARVIS_VOICE_ALWAYS_LISTENING_ON_STARTUP=true
# 0 means no fixed turn limit. Say an exit phrase or press Ctrl+C to stop.
JARVIS_VOICE_ALWAYS_LISTENING_MAX_TURNS=0
JARVIS_VOICE_ALWAYS_LISTENING_START_MODE=sleep_wake

# Useful CLI voice commands:
#   tts status
#   tts providers
#   tts voice list
#   tts voice current
#   tts voice use af_bella
#   tts voice test af_bella play
#   tts test play
#   voice on
#   voice off
# Jarvis persona note: the conversation prompt tells Jarvis to address Tanner as sir.
# 0.1.3 continuous hands-free loop foundation.
# This is still CLI-command controlled/blocking, not a detached background daemon yet.
# Safer default requires a wake phrase each turn. Use conversation start max 3 for no-wake testing.
JARVIS_VOICE_CONTINUOUS_MAX_TURNS=25
JARVIS_VOICE_CONTINUOUS_REQUIRE_WAKE_WORD=true
JARVIS_VOICE_CONTINUOUS_WAIT_FOR_SPEECH=true
JARVIS_VOICE_CONTINUOUS_STOP_PHRASES="stop listening,stop conversation,stop voice loop,stop handsfree,go to sleep,goodbye jarvis,exit voice mode"
JARVIS_VOICE_SLEEP_TIMEOUT_SECONDS=45
JARVIS_VOICE_SLEEP_PHRASES="that's all jarvis,thats all jarvis,that is all jarvis,that will be all jarvis,that'll be all jarvis,go to sleep,sleep mode,stop listening"
JARVIS_VOICE_EXIT_PHRASES="exit voice mode,stop handsfree,stop voice loop,goodbye jarvis,shut down voice loop"

# Useful continuous voice commands:
#   handsfree status
#   startup voice status
#   handsfree start max 5
#   sleep wake start forever
#   wake loop start max 5 silence 0.65
#   conversation start max 3        # no wake word required after command starts
#   voice loop continuous max 5 no wake
# Spoken sleep phrases include: that's all Jarvis, go to sleep, stop listening
# Spoken exit phrases include: exit voice mode, goodbye Jarvis


# 0.1.6a desktop full-runtime startup.
# This makes the desktop UI connect to the real voice runtime so Jarvis can
# listen/sleep/wake through the interface instead of acting like a typed-only UI.
JARVIS_DESKTOP_AUTO_START_VOICE=true
JARVIS_DESKTOP_VOICE_START_MODE=sleep_wake

# 0.1.6b futuristic UI theme + panel system.
# Current built-in themes: jarvis_dark, cyber_blue, stealth_black.
JARVIS_UI_THEME=jarvis_dark
JARVIS_UI_DENSITY=comfortable
